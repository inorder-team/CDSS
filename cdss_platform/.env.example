# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change_me_to_a_secure_random_32_char_string_minimum

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/cdss.db
# DATABASE_URL=postgresql+asyncpg://cdss_user:cdss_pass@localhost:5432/cdss_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=false

# ── ChromaDB / RAG ────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_CLINICAL=cdss_clinical_guidelines
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── KIE Server (Drools Rule Engine) ───────────────────────────────────────────
KIE_SERVER_URL=http://localhost:8180
KIE_SERVER_USER=kieserver
KIE_SERVER_PASSWORD=kieserver1!
KIE_CONTAINER_ID=acs-clinical-rules

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8501

# ── Audit ─────────────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=./logs/audit.jsonl
IMMUTABLE_AUDIT=true
