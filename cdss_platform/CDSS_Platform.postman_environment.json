{
  "id": "cdss-platform-env",
  "name": "CDSS Platform – Local",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "default",
      "enabled": true,
      "description": "Base URL of the running CDSS server"
    },
    {
      "key": "api_prefix",
      "value": "/api/v1",
      "type": "default",
      "enabled": true,
      "description": "API version prefix"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "JWT access token – auto-populated by login requests"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "JWT refresh token – auto-populated by login requests"
    },
    {
      "key": "correlation_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Generate CDSS Recommendation – used by review and audit endpoints"
    },
    {
      "key": "test_username",
      "value": "cardiologist@hospital.local",
      "type": "default",
      "enabled": true,
      "description": "Default test user for login"
    },
    {
      "key": "test_password",
      "value": "SecurePass123!",
      "type": "secret",
      "enabled": true,
      "description": "Default test user password"
    },
    {
      "key": "m2m_client_id",
      "value": "hmis-system",
      "type": "default",
      "enabled": true,
      "description": "Machine-to-machine client ID (HMIS/EMR/PHR/DHA)"
    },
    {
      "key": "m2m_client_secret",
      "value": "hmis-client-secret-here",
      "type": "secret",
      "enabled": true,
      "description": "Machine-to-machine client secret"
    },
    {
      "key": "test_patient_id",
      "value": "PAT-CARD-001",
      "type": "default",
      "enabled": true,
      "description": "Pre-seeded test patient ID"
    },
    {
      "key": "test_encounter_id",
      "value": "ENC-CARD-001",
      "type": "default",
      "enabled": true,
      "description": "Pre-seeded test encounter ID"
    }
  ],
  "_postman_variable_scope": "environment",
  "description": "Environment variables for CDSS Platform API.\n\n## Quick Start\n1. Set `base_url` to your server (default: http://localhost:8000)\n2. Update `test_username` / `test_password` with real Keycloak credentials\n3. Run 'User Login' – `access_token` is auto-saved\n4. All subsequent requests use the token automatically"
}
